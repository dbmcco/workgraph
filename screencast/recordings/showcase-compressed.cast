              \u001b[38;5;6m│\r\n│\u001b[39m                                                               \u001b[38;5;6m│\r\n│\u001b[39m                                                               \u001b[38;5;6m│\r\n│\u001b[39m                                                               \u001b[38;5;6m│\r\n│\u001b[39m                                                               \u001b[38;5;6m│\r\n│\u001b[38;5;8m ↑↓: scroll\u001b[39m                                                    \u001b[38;5;6m│\r\n└───────────────────────────────────────────────────────────────┘\r\n\u001b[1m\u001b[38;5;15m\u001b[48;2;30;30;30m 0:Chat\u001b[0m\u001b[38;2;80;80;80m\u001b[48;2;30;30;30m | \u001b[1m\u001b[38;2;120;120;120mNAV\u001b[0m\u001b[38;2;80;80;80m\u001b[48;2;30;30;30m | \u001b[38;5;3m←→\u001b[38;2;140;140;140m:coordinators  \u001b[38;5;3m+\u001b[38;2;140;140;140m:new  \u001b[38;5;3m-\u001b[38;2;140;140;140m:close  \u001b[38;5;3mEnter\u001b[38;2;140;140;140m:chat  \u001b[38;2;80;80;80m…  │\r\n"]
